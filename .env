# Optional: full managed PostgreSQL connection URL for the ingester.
# When set, this takes precedence over DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.
# Example placeholder:
# DATABASE_URL=postgresql://USER:PASSWORD@managed-db.example.com:5432/RESOURCES
DATABASE_URL=

# PostgreSQL credentials (used when DATABASE_URL is not set)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=RESOURCES
DB_USER=postgres
DB_PASSWORD=postgres

# Grafana credentials
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# Log source - CHANGE THIS to your actual xp65_logs path
LOGS_SOURCE=/home/romain/NCI_gadi/xp65_logs

# Ingestion settings
INGEST_MAX_FILES=0
