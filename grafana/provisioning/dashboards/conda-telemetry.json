          "rawSql": "SELECT s.env_name, count(DISTINCT s.user_id) AS unique_users\nFROM conda_env_sessions s\nWHERE $__timeFilter(s.event_time)\n  AND ('${env_name:raw}' = '__all' OR s.env_name IN (${env_name:sqlstring}))\nGROUP BY s.env_name\nORDER BY unique_users DESC",
