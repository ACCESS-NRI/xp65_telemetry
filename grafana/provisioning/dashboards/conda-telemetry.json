      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day', s.event_time) AS \"time\",\n       p.package_name,\n       count(DISTINCT s.user_id) AS unique_users\nFROM conda_env_sessions s\nJOIN conda_env_packages p ON p.event_hash = s.event_hash\nWHERE $__timeFilter(s.event_time)\n  AND ('${env_name:raw}' = '__all' OR s.env_name IN (${env_name:sqlstring}))\n  AND p.package_name IN ('access_moppy', 'esmvaltool', 'esmvalcore', 'ilamb')\nGROUP BY 1, 2\nORDER BY 1, 2",
          "refId": "A"
        }
      ],
