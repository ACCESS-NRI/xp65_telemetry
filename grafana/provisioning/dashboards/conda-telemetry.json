          "rawSql": "SELECT day AS \"time\", env_name, sessions\nFROM conda_env_daily_usage\nWHERE $__timeFilter(day)\n  AND ('${env_name:raw}' = '__all' OR env_name IN (${env_name:sqlstring}))\nORDER BY 1, 2",
