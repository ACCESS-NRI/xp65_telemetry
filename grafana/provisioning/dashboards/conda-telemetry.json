      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT s.user_id,\n       count(*) AS sessions,\n       count(DISTINCT p.package_name) AS unique_packages,\n       max(s.event_time) AS last_seen\nFROM conda_env_sessions s\nLEFT JOIN conda_env_packages p ON p.event_hash = s.event_hash\nWHERE $__timeFilter(s.event_time)\n  AND ('${env_name:raw}' = '__all' OR s.env_name IN (${env_name:sqlstring}))\nGROUP BY s.user_id\nORDER BY sessions DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Top Users",
      "type": "table"
