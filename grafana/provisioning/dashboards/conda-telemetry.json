      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT s.user_id,\n       count(*) AS sessions,\n       (\n         SELECT count(DISTINCT p.package_name)\n         FROM conda_env_packages p\n         JOIN conda_env_sessions s2 ON s2.event_hash = p.event_hash\n         WHERE s2.user_id = s.user_id\n           AND $__timeFilter(s2.event_time)\n           AND ('${env_name:raw}' = '__all' OR s2.env_name IN (${env_name:sqlstring}))\n       ) AS unique_packages,\n       max(s.event_time) AS last_seen\nFROM conda_env_sessions s\nWHERE $__timeFilter(s.event_time)\n  AND ('${env_name:raw}' = '__all' OR s.env_name IN (${env_name:sqlstring}))\nGROUP BY s.user_id\nORDER BY sessions DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Top Users",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
