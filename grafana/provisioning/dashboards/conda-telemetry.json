      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT env_name, package_name, package_uses, package_rank\nFROM conda_env_package_ranking_by_env\nWHERE ('${env_name:raw}' = '__all' OR env_name IN (${env_name:sqlstring}))\n  AND left(package_name, 1) <> '_'\nORDER BY env_name, package_rank",
          "refId": "A"
        }
